local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local API_URL = "https://api.xstar.site" -- Senin Vercel domain adresin

-- 1. STEP: BACKEND ÜZERİNDEN GÜNCEL REKLAM LİNKİNİ ÇEKME
local LinkvertiseLinki = "https://linkvertise.com" 
local success, response = pcall(function()
    return HttpService:JSONDecode(game:HttpGet(API_URL .. "/get-link"))
end)
if success and response and response.link then
    LinkvertiseLinki = response.link
end

-- İlk çalıştırmada linki panoya otomatik kopyala
if setclipboard then setclipboard(LinkvertiseLinki) end

-- 2. STEP: ANA HİLE FONKSİYONU
local function LoadMainCheat()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({
       Name = "XSTAR - Arsenal PvP Crusher",
       LoadingTitle = "XSTAR Motion Engine v4.0",
       LoadingSubtitle = "by Zukan (PvP Edition)",
       ConfigurationSaving = { Enabled = true, FolderName = "XStarArsenalData", FileName = "PvPConfig" },
       KeySystem = false 
    })

    -- SERVİSLER VE CONFIG
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local Camera = workspace.CurrentCamera
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")

    local Config = {
        Aimbot = false, SilentAim = false, TeamCheck = true, WallCheck = false,
        AimPart = "Head", FovRadius = 150, FovVisible = true, Smoothing = 0.05,
        NoRecoil = false, NoSpread = false, InfiniteAmmo = false, RapidFire = false, EspBox = false
    }

    -- TABS
    local CombatTab = Window:CreateTab("Combat (Aim)", 4483362458)
    local GunTab = Window:CreateTab("Gun Mods", 4483362458)
    local VisualsTab = Window:CreateTab("Visuals (ESP)", 4483362458)

    CombatTab:CreateToggle({Name = "Camera Aimbot", CurrentValue = false, Callback = function(v) Config.Aimbot = v end})
    CombatTab:CreateToggle({Name = "Silent Aim", CurrentValue = false, Callback = function(v) Config.SilentAim = v end})
    CombatTab:CreateSlider({Name = "Smoothing", Range = {0, 1}, Increment = 0.01, CurrentValue = 0.05, Callback = function(v) Config.Smoothing = v end})
    CombatTab:CreateSlider({Name = "FOV Radius", Range = {50, 500}, Increment = 5, CurrentValue = 150, Callback = function(v) Config.FovRadius = v end})
    
    GunTab:CreateToggle({Name = "No Recoil", CurrentValue = false, Callback = function(v) Config.NoRecoil = v end})
    GunTab:CreateToggle({Name = "Infinite Ammo", CurrentValue = false, Callback = function(v) Config.InfiniteAmmo = v end})

    VisualsTab:CreateToggle({Name = "Box ESP (Red)", CurrentValue = false, Callback = function(v) Config.EspBox = v end})

    -- LOOP (Gelişmiş Aimbot & ESP)
    local FovCircle = Drawing.new("Circle")
    FovCircle.Thickness = 1
    FovCircle.Color = Color3.fromRGB(255, 0, 0)
    FovCircle.Transparency = 0.6

    RunService.RenderStepped:Connect(function()
        FovCircle.Position = UserInputService:GetMouseLocation()
        FovCircle.Radius = Config.FovRadius
        FovCircle.Visible = Config.FovVisible

        if Config.EspBox then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    if Config.TeamCheck and p.Team == LocalPlayer.Team then continue end
                    if not p.Character:FindFirstChild("Highlight") then
                        local hl = Instance.new("Highlight", p.Character)
                        hl.FillColor = Color3.fromRGB(255, 0, 0)
                    end
                end
            end
        end
    end)
end

