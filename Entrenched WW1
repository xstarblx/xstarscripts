local function VerifyKeyWithAPI(InputKey)
    local checkSuccess, checkResponse = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(API_URL .. "/check-key?key=" .. tostring(InputKey)))
    end)
    
    if checkSuccess and checkResponse and checkResponse.success then
        return true
    else
        return false
    end
end

