-- ==========================================
-- ANA DÖNGÜ (ADAMIN KAFASINDAN AYRILMAZ)
-- ==========================================

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Values.AimbotTusu then Kilitli = true end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Values.AimbotTusu then 
        Kilitli = false 
        MevcutHedef = nil -- Tuşu bırakınca hedefi sal
    end
end)

RunService.RenderStepped:Connect(function()
    FovCircle.Position = UserInputService:GetMouseLocation()
    FovCircle.Radius = Values.FovRadius
    FovCircle.Visible = Toggles.FovVisible

    if Kilitli and Toggles.Aimbot then
        MevcutHedef = GetClosestTarget()
        
        if MevcutHedef then
            local RootPart = MevcutHedef.Parent:FindFirstChild("HumanoidRootPart")
            local PredictPos = MevcutHedef.Position
            
            -- HAREKETLİ HEDEF TAHMİNİ (PREDICTION)
            if Toggles.Prediction and RootPart then
                -- Mesafe arttıkça tahmini artıran formül (Entrenched için özel)
                local Mesafe = (Camera.CFrame.Position - MevcutHedef.Position).Magnitude
                local DinamikPred = Values.PredictionHizi + (Mesafe / 5000) 
                PredictPos = PredictPos + (RootPart.Velocity * DinamikPred)
            end

            -- KİLİTLENME (LERP)
            local LookAt = CFrame.new(Camera.CFrame.Position, PredictPos)
            
            -- Eğer Smoothing 0 ise tak diye kitlenir
            if Values.Smoothing <= 0.01 then
                Camera.CFrame = LookAt
            else
                Camera.CFrame = Camera.CFrame:Lerp(LookAt, 1 - Values.Smoothing)
            end
        end
    end
    
    -- RED ESP (ONLY ENEMIES)
    if Toggles.Esp then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                if Toggles.TeamCheck and p.Team == LocalPlayer.Team then
                    if p.Character:FindFirstChild("Highlight") then p.Character.Highlight:Destroy() end
                    continue
                end

                local hl = p.Character:FindFirstChild("Highlight")
                if not hl then
                    hl = Instance.new("Highlight", p.Character)
                    hl.FillColor = Color3.fromRGB(255, 0, 0)
                    hl.OutlineTransparency = 1
                    hl.FillAlpha = 0.5
                end
            end
        end
    end
end)

